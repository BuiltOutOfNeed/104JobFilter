{
  "manifest_version": 3,
  "name": "104 求職過濾器 | 104 Job Filter",
  "version": "1.1.0",
  "description": "Hide and highlight job listings on 104.com.tw using keywords. Supports regex, color-coded highlights, and applied company scraping.",
  "homepage_url": "https://github.com/BuiltOutOfNeed/104JobFilter",
  "author": "BuiltOutOfNeed",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://*.104.com.tw/*"],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.104.com.tw/*"],
      "js": [
        "src/shared/constants.js",
        "src/shared/storage.js",
        "src/content/cardFinder.js",
        "src/content/filter.js",
        "src/content/observer.js",
        "src/content/scraper.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
